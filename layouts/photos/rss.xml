{{- $pages := .RegularPages -}}
{{- $pages = where $pages "Draft" false -}}
{{- $pages = where $pages "Date" "<=" now -}}
{{- $pages = sort $pages "Date" "desc" -}}
{{- $pages = first 20 $pages -}}
{{- $feed := .OutputFormats.Get "RSS" -}}
{{- $description := .Description | default (printf "Latest photo albums from %s" site.Title) -}}
{{- printf "<?xml version=\"1.0\" encoding=\"UTF-8\"?>" | safeHTML -}}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ .Title }} | {{ site.Title }}</title>
    <link>{{ .Permalink }}</link>
    {{- with $feed }}
    <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml" />
    {{- end }}
    <description>{{ $description | plainify }}</description>
    <language>{{ site.Language.Locale }}</language>
    <generator>Hugo {{ hugo.Version }}</generator>
    <ttl>60</ttl>
    {{- $mimeTypes := dict "jpg" "image/jpeg" "jpeg" "image/jpeg" "png" "image/png" "webp" "image/webp" }}
    {{- range $pages }}
    {{- $r2base    := site.Params.r2BaseURL }}
    {{- $rawLinks  := findRE `href="https://[^/"]+/[^/"]+\.[a-z]+"` .Content }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <guid isPermaLink="true">{{ .Permalink }}</guid>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      {{- with .Description }}
      <description>{{ . | transform.XMLEscape | safeHTML }}</description>
      {{- end }}
      {{- range $rawLinks }}
      {{- $url  := . | replaceRE `^href="` "" | replaceRE `"$` "" }}
      {{- $ext  := path.Ext $url | strings.TrimPrefix "." | lower }}
      {{- $mime := index $mimeTypes $ext | default "image/jpeg" }}
      {{- $thumb := printf "%s/%s/%s" $r2base site.Params.r2Thumb (path.Base $url) }}
      <media:content url="{{ $url }}" medium="image" type="{{ $mime }}">
        <media:thumbnail url="{{ $thumb }}"/>
      </media:content>
      {{- end }}
    </item>
    {{- end }}
  </channel>
</rss>
